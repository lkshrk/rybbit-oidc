NODE_ENV=development

# ClickHouse configuration
CLICKHOUSE_HOST=http://localhost:8123
CLICKHOUSE_DB=analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# PostgreSQL configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=analytics
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# Redis configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Authentication
BETTER_AUTH_SECRET=your-secret-key-here

# Optional OpenID Connect provider.
# Redirect URL: ${BASE_URL}/api/auth/oauth2/callback/oidc
OIDC_NAME="Acme SSO"
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_DISCOVERY_URL=https://idp.example.com/.well-known/openid-configuration
OIDC_SCOPES=openid,profile,email,groups
OIDC_GROUP_CLAIM=groups
# JSON array. teamNames are created if missing; teamIds must already exist.
OIDC_GROUP_MAPPING='[{"group":"analytics-admins","organizationId":"org_id","role":"admin","teamNames":["Analytics"]}]'

# Stripe (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# AppSumo (optional - cloud only)
APPSUMO_CLIENT_ID=
APPSUMO_CLIENT_SECRET=

# R2 Storage (optional)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
